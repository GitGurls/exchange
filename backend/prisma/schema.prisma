generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  balances  Balance[]
  orders    Order[]

  @@map("users")
}

model Balance {
  id       String @id @default(uuid())
  userId   String
  asset    String // "INR" or "TATA" etc
  available Float  @default(0)
  locked    Float  @default(0) // locked in open orders

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, asset])
  @@map("balances")
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  market    String      // e.g. "TATA_INR"
  side      OrderSide
  type      OrderType
  price     Float?      // null for market orders
  quantity  Float
  filled    Float       @default(0)
  status    OrderStatus @default(OPEN)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  fills Fill[] @relation("buyFills")
  sellFills Fill[] @relation("sellFills")

  @@index([market, status])
  @@index([userId])
  @@map("orders")
}

model Fill {
  id          String   @id @default(uuid())
  market      String
  price       Float
  quantity    Float
  buyOrderId  String
  sellOrderId String
  timestamp   DateTime @default(now())

  buyOrder  Order @relation("buyFills",  fields: [buyOrderId],  references: [id])
  sellOrder Order @relation("sellFills", fields: [sellOrderId], references: [id])

  @@index([market])
  @@map("fills")
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}
